{
  "name": "@gmacko/nextjs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules playwright-report storybook-static test-results",
    "dev": "pnpm with-env next dev",
    "dev:vinext": "pnpm prebuild:vinext && VINEXT=1 pnpm with-env vinext dev --port 3001",
    "build:vinext": "pnpm prebuild:vinext && VINEXT=1 pnpm with-env vinext build && pnpm sync:vinext-wrangler",
    "start:vinext": "VINEXT=1 pnpm with-env vinext start",
    "prebuild:vinext": "pnpm --dir ../.. --filter @gmacko/nextjs^... build",
    "sync:vinext-wrangler": "node ./scripts/sync-vinext-wrangler.mjs",
    "deploy:cloudflare": "pnpm deploy:cloudflare:production",
    "deploy:cloudflare:staging": "pnpm with-env wrangler deploy --env staging",
    "deploy:cloudflare:production": "pnpm with-env wrangler deploy",
    "format": "biome check .",
    "lint": "oxlint .",
    "storybook": "SKIP_ENV_VALIDATION=1 storybook dev -p 6006",
    "storybook:build": "SKIP_ENV_VALIDATION=1 storybook build",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@gmacko/analytics": "workspace:*",
    "@gmacko/api": "workspace:*",
    "@gmacko/auth": "workspace:*",
    "@gmacko/config": "workspace:*",
    "@gmacko/db": "workspace:*",
    "@gmacko/email": "workspace:*",
    "@gmacko/i18n": "workspace:*",
    "@gmacko/monitoring": "workspace:*",
    "@gmacko/realtime": "workspace:*",
    "@gmacko/ui": "workspace:*",
    "@gmacko/validators": "workspace:*",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@sentry/nextjs": "^10.44.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "superjson": "catalog:",
    "tailwind-merge": "^3.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@cloudflare/vite-plugin": "^1.32.3",
    "@gmacko/tailwind-config": "workspace:*",
    "@gmacko/tsconfig": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/nextjs-vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "@vitejs/plugin-rsc": "^0.5.24",
    "jiti": "^2.6.1",
    "oxlint": "catalog:",
    "react-server-dom-webpack": "^19.2.5",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vinext": "^0.0.41",
    "vite": "catalog:",
    "wrangler": "^4.83.0"
  }
}
